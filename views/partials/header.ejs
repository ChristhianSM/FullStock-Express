<header class="root__header">
  <div class="auth-nav">
    <div class="container auth-nav__container">
      <nav aria-label="Autenticación de usuario">
        <ul class="auth-nav__list">
          <% if(locals.user) {%>
          <li class="auth-nav__item">Bienvenido <%= user.email %></li>
          <li class="auth-nav__item">
            <form action="/auth/logout" method="POST">
              <button class="button button--ghost auth-nav__button">
                Cerrar sesión
              </button>
            </form>
          </li>
          <% } else { %>
          <li class="auth-nav__item">
            <a href="/auth/login" class="auth-nav__link">Iniciar sesión </a>
          </li>
          <li class="auth-nav__item">
            <a href="/auth/signup" class="auth-nav__link">Crear una cuenta </a>
          </li>
          <% } %>
        </ul>
      </nav>
    </div>
  </div>
  <div class="container header-main">
    <div class="header-main__top">
      <a href="/">
        <img
          src="/images/fullstock-logo.svg"
          alt="FullStock inicio"
          width="128"
          height="32"
        />
      </a>
      <div class="header-actions">
        <a
          href="/cart"
          class="button button--ghost button--xl-icon header-actions__cart"
          aria-label="Carrito de compras"
        >
          <img src="/images/icons/cart.svg" alt="Carrito de compras" />
          <span class="header-actions__cart-badge"
            ><%= countCartProducts %></span
          >
        </a>
      </div>
    </div>
    <div class="separator header-main__separator"></div>
    <nav aria-label="Navegación principal" class="main-nav">
      <ul class="main-nav__list" role="menubar">
        <li class="main-nav__item" role="none">
          <a href="/category/polos" role="menuitem" class="main-nav__link"
            >Polos</a
          >
        </li>
        <li class="main-nav__item" role="none">
          <a href="/category/tazas" role="menuitem" class="main-nav__link"
            >Tazas</a
          >
        </li>
        <li class="main-nav__item" role="none">
          <a href="/category/stickers" role="menuitem" class="main-nav__link"
            >Stickers</a
          >
        </li>
      </ul>
    </nav>
  </div>
</header>
